[host_machine]
system = 'windows'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'

[binaries]
c = 'winegcc'
cpp = 'wineg++'
ar = 'ar'
strip = 'strip'
pkgconfig = '/usr/bin/pkg-config'

[properties]
# Dependencies are for the build machine (Linux), not host (Windows)
# So pkg-config should check the build machine

# Define that we don't need external dependencies for Windows
# All Windows dependencies come from Wine
